# 火山引擎方舟 API 配置
# 请将 your_api_key_here 替换为你的实际 API Key
ARK_API_KEY=your_api_key_here

# 火山引擎方舟模型端点
# 请将 your_model_endpoint_here 替换为你的实际模型端点
ARK_MODEL_ENDPOINT=your_model_endpoint_here

# Milvus 配置（可选）
# 如果你想使用 Milvus 数据库存储卦辞，请配置以下参数
MILVUS_ADDRESS=localhost:19530
MILVUS_USERNAME=
MILVUS_PASSWORD=

# 注意：
# 1. 复制此文件为 .env 并填入实际值
# 2. .env 文件已被 .gitignore 忽略，不会提交到 git
# 3. 不要将包含真实 API Key 的 .env 文件提交到公开仓库！
