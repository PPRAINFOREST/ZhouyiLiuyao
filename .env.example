# 周易算卦 Agent - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# 注意：.env 文件已被 .gitignore 忽略，不会提交到 git

# ==========================================
# 火山引擎方舟 API 配置（必填）
# ==========================================

# 火山引擎方舟 API Key
# 获取地址：https://console.volcengine.com/ark/
# 注意：这是您自己的 API Key，请妥善保管，不要泄露
ARK_API_KEY=your_ark_api_key_here

# 模型名称
MODEL=doubao-seed-2-0-pro-260215

# 嵌入模型名称
EMBEDDER=doubao-embedding-vision-251215

# ==========================================
# Zilliz Cloud 配置（已配置好，可直接使用）
# ==========================================

# Zilliz Cloud 公网地址
# 项目已配置好可公开访问的数据库，无需自己创建
MILVUS_ADDRESS=https://in03-1eb38c285b461bb.serverless.aws-eu-central-1.cloud.zilliz.com

# Zilliz Cloud API Key（只读权限）
# 项目提供的只读 API Key，可以直接使用
# 此 Key 仅用于查询卦辞，无法修改数据
MILVUS_API_KEY=1242aac85db8fcde3bc25397291aa190bb45d6e379f9c917f25580a801d612e5d760baa9c602c0e5f04ca3fd2daa2f8d5af779b8

# ==========================================
# 说明
# ==========================================
#
# 1. 必填配置：
#    - ARK_API_KEY：必须填写，这是您自己的火山引擎方舟 API Key
#
# 2. 数据库配置：
#    - MILVUS_ADDRESS 和 MILVUS_API_KEY：
#      - 项目已配置好可公开访问的 Zilliz Cloud 数据库
#      - 包含完整的 64 卦卦辞数据
#      - 使用的是只读 API Key，无法修改数据
#      - 可以直接使用，无需自己创建数据库
#
# 3. 安全提醒：
#    - 不要将包含真实密钥的 .env 文件提交到公开仓库！
#    - 只提交 .env.example 作为模板
#    - ARK_API_KEY 是您自己的，请妥善保管
#    - MILVUS_API_KEY 是只读的，可以公开分享
