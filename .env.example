# 环境变量配置文件
# 复制此文件为 .env 并填入您的配置

# ==========================================
# 火山引擎方舟 API 配置（必需）
# ==========================================

# 您的火山引擎方舟 API Key
# 获取地址：https://console.volcengine.com/ark
ARK_API_KEY=your_api_key_here

# 模型端点（可选，如果使用默认端点可以不填）
ARK_MODEL_ENDPOINT=

# ==========================================
# Milvus 向量数据库配置（可选，预留功能）
# ==========================================

# Milvus 服务地址
MILVUS_ADDRESS=localhost:19530

# Milvus 数据库名称
MILVUS_DATABASE=default

# ==========================================
# 其他配置
# ==========================================

# 日志级别（debug, info, warn, error）
LOG_LEVEL=info
